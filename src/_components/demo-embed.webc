<figure class="demo-block" webc:root="override">
	<figcaption class="demo-block__header cluster repel">
		<span aria-hidden="true"
			><svg-icon
				class="demo-block__icon"
				id="live-demo"
			></svg-icon
		></span>
		<dl>
			<dt class="visually-hidden">Demo</dt>
			<dd @text="name"></dd>
		</dl>
	</figcaption>
	<div class="demo-block__content">
		<slot></slot>
	</div>
</figure>

<style webc:scoped>
	.demo-block {
		display: block;
		border: 1px solid;
	}
	.demo-block__content {
	}
</style>
